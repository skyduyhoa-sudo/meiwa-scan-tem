// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Role {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  status    String   @default("Đang hoạt động")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  users     User[]
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  firstName String
  lastName  String
  email     String?
  phone     String?
  status    String   @default("Đang hoạt động")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  roleId    Int?
  role      Role?    @relation(fields: [roleId], references: [id])
  dob       String?
  gender    String?
  avatarUrl String?
}

model Partner {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  fullName  String
  status    String    @default("Đang hoạt động")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]
}

model Product {
  id        Int      @id @default(autoincrement())
  name      String
  code      String   @unique
  status    String   @default("Đang hoạt động")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  partnerId Int
  partner   Partner  @relation(fields: [partnerId], references: [id])
}

model PackingList {
  id             Int      @id @default(autoincrement())
  boxNo          String
  code           String
  lotNo          String
  item           String
  rank           String
  quantity       Int
  total          Int
  packDate       String?
  warrantyPeriod String?
  seriNumber     String?
  poNumber       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Invoice {
  id             Int      @id @default(autoincrement())
  invoiceNo      String?
  poNumber       String?
  code           String
  quantity       Int
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model ProcessDoc {
  id             Int      @id @default(autoincrement())
  docNo          String?
  code           String
  lotNo          String
  quantity       Int
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Log {
  id        Int      @id @default(autoincrement())
  type      String   // INFO, ERROR
  message   String
  createdAt DateTime @default(now())
}

model LotDetail {
  id             Int      @id @default(autoincrement())
  productName    String?
  meiwaCode      String?
  customerCode   String?
  lotNo          String
  quantity       Int
  boxNo          String?
  poNumber       String?
  seriNumber     String?
  packDate       String?
  operator       String?
  machineNo      String?
  netWeight      Float?
  grossWeight    Float?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model ScanHistory {
  id             Int      @id @default(autoincrement())
  barcode        String
  cartonNo       String?
  scanType       String   // TEM_BICH, TEM_THUNG
  status         String   // OK, NG
  reason         String?
  createdAt      DateTime @default(now())
}